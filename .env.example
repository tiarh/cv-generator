# CV Generator Environment Configuration

# Server
PORT=8083
NODE_ENV=development

# AI Configuration (OpenRouter)
# Get your API key from https://openrouter.ai/
OPENROUTER_API_KEY=

# AI Model (default: google/gemma-3-27b-it)
# Options: google/gemma-3-27b-it, anthropic/claude-3.5-sonnet, openai/gpt-4o
AI_MODEL=google/gemma-3-27b-it

# Optional: Anthropic Direct (alternative to OpenRouter)
# ANTHROPIC_API_KEY=

# Database
DB_PATH=./db/cvgenerator.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30