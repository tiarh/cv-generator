[Unit]
Description=CV Generator v2
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/superagent-v3/cv-generator
ExecStart=/root/superagent-v3/cv-generator/.venv/bin/python app.py
Restart=always
RestartSec=5
Environment="HOST=0.0.0.0"
Environment="PORT=5000"
Environment="SECRET_KEY=change-me-in-prod"

[Install]
WantedBy=multi-user.target