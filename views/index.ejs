<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CV Generator - ATS-Friendly Resume Builder</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .template-card:hover .template-overlay { opacity: 1; }
    .template-card:hover { transform: translateY(-4px); }
  </style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 min-h-screen">
  
  <!-- Header -->
  <header class="py-6 px-8">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-500 rounded-lg flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <span class="text-white font-bold text-xl">CV Generator</span>
      </div>
      <a href="/drafts" class="text-blue-300 hover:text-white transition flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/>
        </svg>
        My Drafts
      </a>
    </div>
  </header>

  <!-- Hero Section -->
  <main class="max-w-6xl mx-auto px-8 py-12">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">
        Build Your <span class="text-blue-400">ATS-Optimized</span> Resume
      </h1>
      <p class="text-lg text-blue-200 max-w-2xl mx-auto">
        Create professional, ATS-friendly resumes with AI-powered descriptions. 
        Choose from 3 expert-designed templates and download in PDF format.
      </p>
    </div>

    <!-- Template Selection -->
    <div class="mb-12">
      <h2 class="text-xl font-semibold text-white mb-6 text-center">Choose a Template</h2>
      <div class="grid md:grid-cols-3 gap-6">
        
        <!-- ATS Modern -->
        <div class="template-card relative bg-white rounded-2xl overflow-hidden shadow-xl transition-all duration-300 cursor-pointer group" onclick="startWizard('ats-modern')">
          <div class="aspect-[3/4] bg-gradient-to-br from-blue-50 to-indigo-100 p-6">
            <div class="h-8 w-32 bg-blue-600 rounded mb-4"></div>
            <div class="h-3 w-full bg-gray-300 rounded mb-2"></div>
            <div class="h-3 w-3/4 bg-gray-200 rounded mb-4"></div>
            <div class="h-3 w-full bg-gray-300 rounded mb-2"></div>
            <div class="h-3 w-5/6 bg-gray-200 rounded mb-6"></div>
            <div class="h-4 w-24 bg-blue-500 rounded mb-3"></div>
            <div class="h-2 w-full bg-gray-200 rounded mb-1"></div>
            <div class="h-2 w-4/5 bg-gray-200 rounded mb-1"></div>
            <div class="h-2 w-full bg-gray-200 rounded"></div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">ATS-Modern</h3>
            <p class="text-gray-600 text-sm">Clean, single-column design with modern styling. Perfect for tech roles.</p>
            <div class="mt-4 flex items-center text-blue-600 font-medium text-sm">
              Use this template
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
          <div class="template-overlay absolute inset-0 bg-blue-600 bg-opacity-90 flex items-center justify-center opacity-0 transition-opacity duration-300">
            <span class="text-white font-semibold text-lg">Start Creating →</span>
          </div>
        </div>

        <!-- ATS Classic -->
        <div class="template-card relative bg-white rounded-2xl overflow-hidden shadow-xl transition-all duration-300 cursor-pointer group" onclick="startWizard('ats-classic')">
          <div class="aspect-[3/4] bg-gradient-to-br from-slate-50 to-gray-100 p-6">
            <div class="flex gap-4 mb-4">
              <div class="flex-1">
                <div class="h-8 w-28 bg-slate-800 rounded mb-3"></div>
                <div class="h-2 w-full bg-gray-400 rounded mb-1"></div>
                <div class="h-2 w-3/4 bg-gray-300 rounded mb-4"></div>
                <div class="h-4 w-20 bg-slate-700 rounded mb-2"></div>
                <div class="h-2 w-full bg-gray-300 rounded mb-1"></div>
                <div class="h-2 w-5/6 bg-gray-300 rounded mb-1"></div>
                <div class="h-2 w-full bg-gray-300 rounded"></div>
              </div>
              <div class="w-16 h-16 bg-slate-200 rounded"></div>
            </div>
            <div class="h-4 w-20 bg-slate-700 rounded mb-2"></div>
            <div class="h-2 w-full bg-gray-300 rounded mb-1"></div>
            <div class="h-2 w-4/5 bg-gray-300 rounded mb-1"></div>
            <div class="h-2 w-full bg-gray-300 rounded"></div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">ATS-Classic</h3>
            <p class="text-gray-600 text-sm">Traditional two-column layout with serif typography. Professional and timeless.</p>
            <div class="mt-4 flex items-center text-blue-600 font-medium text-sm">
              Use this template
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
          <div class="template-overlay absolute inset-0 bg-blue-600 bg-opacity-90 flex items-center justify-center opacity-0 transition-opacity duration-300">
            <span class="text-white font-semibold text-lg">Start Creating →</span>
          </div>
        </div>

        <!-- ATS Minimal -->
        <div class="template-card relative bg-white rounded-2xl overflow-hidden shadow-xl transition-all duration-300 cursor-pointer group" onclick="startWizard('ats-minimal')">
          <div class="aspect-[3/4] bg-white p-6">
            <div class="h-6 w-24 bg-black rounded mb-6"></div>
            <div class="space-y-2 mb-6">
              <div class="h-2 w-full bg-gray-200 rounded"></div>
              <div class="h-2 w-5/6 bg-gray-200 rounded"></div>
            </div>
            <div class="h-3 w-16 bg-black rounded mb-3"></div>
            <div class="space-y-1 mb-4">
              <div class="h-2 w-full bg-gray-200 rounded"></div>
              <div class="h-2 w-4/5 bg-gray-200 rounded"></div>
            </div>
            <div class="h-3 w-16 bg-black rounded mb-3"></div>
            <div class="space-y-1">
              <div class="h-2 w-full bg-gray-200 rounded"></div>
              <div class="h-2 w-3/4 bg-gray-200 rounded"></div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-gray-900 text-lg mb-2">ATS-Minimal</h3>
            <p class="text-gray-600 text-sm">Ultra-clean design with maximum whitespace. ATS-optimized with no graphics.</p>
            <div class="mt-4 flex items-center text-blue-600 font-medium text-sm">
              Use this template
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
          <div class="template-overlay absolute inset-0 bg-blue-600 bg-opacity-90 flex items-center justify-center opacity-0 transition-opacity duration-300">
            <span class="text-white font-semibold text-lg">Start Creating →</span>
          </div>
        </div>

      </div>
    </div>

    <!-- Features -->
    <div class="grid md:grid-cols-3 gap-6 text-center">
      <div class="bg-white bg-opacity-5 backdrop-blur rounded-xl p-6">
        <div class="w-12 h-12 bg-blue-500 rounded-lg mx-auto mb-4 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">AI-Powered</h3>
        <p class="text-blue-200 text-sm">Generate professional descriptions with AI or use smart templates</p>
      </div>
      <div class="bg-white bg-opacity-5 backdrop-blur rounded-xl p-6">
        <div class="w-12 h-12 bg-green-500 rounded-lg mx-auto mb-4 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">ATS-Optimized</h3>
        <p class="text-blue-200 text-sm">All templates designed to pass Applicant Tracking Systems</p>
      </div>
      <div class="bg-white bg-opacity-5 backdrop-blur rounded-xl p-6">
        <div class="w-12 h-12 bg-purple-500 rounded-lg mx-auto mb-4 flex items-center justify-center">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h3 class="text-white font-semibold mb-2">PDF Export</h3>
        <p class="text-blue-200 text-sm">Download your resume as a professional PDF document</p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="mt-16 text-center text-blue-300 text-sm">
      <p>Built with Node.js + Express + EJS • Data stored locally in SQLite</p>
    </footer>
  </main>

  <script>
    function startWizard(template) {
      window.location.href = `/wizard/${template}`;
    }
  </script>
</body>
</html>