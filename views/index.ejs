<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CV Generator - Create Professional ATS-Friendly Resumes</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">
  <style>body{font-family:'Inter',sans-serif;}</style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 min-h-screen">

  <!-- Header -->
  <header class="py-6 px-4 md:px-8">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-500 rounded-xl flex items-center justify-center shadow-lg">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <span class="text-white font-bold text-xl tracking-tight">CV Generator</span>
      </div>
      <a href="/drafts" class="text-blue-200 hover:text-white font-medium text-sm transition flex items-center gap-2 bg-white/10 px-4 py-2 rounded-lg">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2"/></svg>
        My Drafts
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 md:px-8 py-12 md:py-20">
    <div class="text-center max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 bg-blue-500/20 text-blue-200 px-4 py-1.5 rounded-full text-sm font-medium mb-6 border border-blue-400/30">
        <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
        AI-Powered Resume Builder
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight mb-6">
        Create a Resume That <span class="text-blue-400">Gets You Hired</span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100/80 mb-8 leading-relaxed">
        ATS-friendly templates with AI-generated professional descriptions. Build, preview, and download your CV in minutes — not hours.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#templates" class="bg-blue-500 hover:bg-blue-600 text-white px-8 py-4 rounded-xl font-bold text-lg transition shadow-lg shadow-blue-500/25 flex items-center justify-center gap-2">
          Start Building 
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/drafts" class="bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-xl font-bold text-lg transition border border-white/20 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Resume Draft
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 md:px-8 pb-12">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 hover:border-blue-400/30 transition">
        <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <h3 class="text-white font-bold text-lg mb-2">AI Smart Write</h3>
        <p class="text-blue-200/70 text-sm leading-relaxed">Auto-generate professional, quantified job descriptions based on your role. No more staring at blank pages.</p>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 hover:border-blue-400/30 transition">
        <div class="w-12 h-12 bg-green-500/20 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-green-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="text-white font-bold text-lg mb-2">ATS Optimized</h3>
        <p class="text-blue-200/70 text-sm leading-relaxed">Clean, scannable templates that pass Applicant Tracking Systems. Proper heading hierarchy with no tables for layout.</p>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 hover:border-blue-400/30 transition">
        <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
        </div>
        <h3 class="text-white font-bold text-lg mb-2">PDF Export</h3>
        <p class="text-blue-200/70 text-sm leading-relaxed">One-click download as professional PDF. Preview before you save. Auto-saves your progress as you type.</p>
      </div>
    </div>
  </section>

  <!-- Templates -->
  <section id="templates" class="max-w-6xl mx-auto px-4 md:px-8 pb-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Choose Your Template</h2>
      <p class="text-blue-200/70">All templates are ATS-friendly and fully customizable</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- ATS Modern -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-2xl hover:shadow-blue-500/20 transition-all duration-300 hover:-translate-y-1 group">
        <div class="bg-gradient-to-br from-blue-50 to-indigo-50 p-6 h-48 flex items-center justify-center border-b">
          <div class="w-full max-w-[200px] bg-white rounded-lg shadow-sm p-3 border border-gray-100">
            <div class="h-2.5 w-20 bg-blue-500 rounded mb-2"></div>
            <div class="h-1.5 w-full bg-gray-200 rounded mb-1"></div>
            <div class="h-1.5 w-10 bg-gray-200 rounded mb-3"></div>
            <div class="h-px bg-gray-200 my-2"></div>
            <div class="h-1.5 w-16 bg-blue-400 rounded mb-1.5"></div>
            <div class="h-1 w-full bg-gray-200 rounded mb-1"></div>
            <div class="h-1 w-16 bg-gray-200 rounded"></div>
          </div>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2.5 h-2.5 bg-blue-500 rounded-full"></span>
            <h3 class="font-bold text-lg text-gray-900">ATS Modern</h3>
          </div>
          <p class="text-gray-500 text-sm mb-4">Clean single-column layout with modern styling. Color accents and professional typography.</p>
          <ul class="space-y-1.5 text-xs text-gray-500 mb-6">
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> Best for tech & startups</li>
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> Color accent sections</li>
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> 98.5% ATS pass rate</li>
          </ul>
          <a href="/wizard/ats-modern" class="block w-full bg-blue-600 hover:bg-blue-700 text-white text-center py-3 rounded-xl font-semibold transition">Use This Template</a>
        </div>
      </div>

      <!-- ATS Classic -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-2xl hover:shadow-amber-500/20 transition-all duration-300 hover:-translate-y-1 group">
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 p-6 h-48 flex items-center justify-center border-b">
          <div class="flex w-full max-w-[200px] gap-2">
            <div class="flex-1">
              <div class="h-2 w-16 bg-gray-800 rounded mb-2"></div>
              <div class="h-1 w-full bg-gray-200 rounded mb-1"></div>
              <div class="h-1 w-8 bg-gray-200 rounded mb-2"></div>
              <div class="h-px bg-gray-200 mb-2"></div>
              <div class="h-1 w-14 bg-gray-700 rounded mb-1"></div>
              <div class="h-0.5 w-full bg-gray-200 rounded"></div>
            </div>
            <div class="w-16 border-l pl-2">
              <div class="h-1 w-10 bg-gray-700 rounded mb-1"></div>
              <div class="h-0.5 w-full bg-gray-200 rounded mb-0.5"></div>
              <div class="h-0.5 w-6 bg-gray-200 rounded"></div>
            </div>
          </div>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2.5 h-2.5 bg-amber-500 rounded-full"></span>
            <h3 class="font-bold text-lg text-gray-900">ATS Classic</h3>
          </div>
          <p class="text-gray-500 text-sm mb-4">Traditional two-column layout. Serif fonts and minimal styling for a timeless look.</p>
          <ul class="space-y-1.5 text-xs text-gray-500 mb-6">
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> Best for traditional industries</li>
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> Two-column layout</li>
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> 99% ATS pass rate</li>
          </ul>
          <a href="/wizard/ats-classic" class="block w-full bg-amber-600 hover:bg-amber-700 text-white text-center py-3 rounded-xl font-semibold transition">Use This Template</a>
        </div>
      </div>

      <!-- ATS Minimal -->
      <div class="bg-white rounded-2xl overflow-hidden shadow-2xl hover:shadow-gray-500/20 transition-all duration-300 hover:-translate-y-1 group">
        <div class="bg-gradient-to-br from-gray-50 to-slate-50 p-6 h-48 flex items-center justify-center border-b">
          <div class="w-full max-w-[200px]">
            <div class="h-2.5 w-20 bg-gray-900 rounded mb-1"></div>
            <div class="h-1 w-10 bg-gray-400 rounded mb-4"></div>
            <div class="h-px bg-gray-200 my-1"></div>
            <div class="h-0.5 w-12 bg-gray-500 rounded mb-1"></div>
            <div class="h-0.5 w-full bg-gray-200 rounded mb-0.5"></div>
            <div class="h-0.5 w-8 bg-gray-300 rounded"></div>
          </div>
        </div>
        <div class="p-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2.5 h-2.5 bg-gray-500 rounded-full"></span>
            <h3 class="font-bold text-lg text-gray-900">ATS Minimal</h3>
          </div>
          <p class="text-gray-500 text-sm mb-4">Ultra-clean, maximum whitespace. No graphics, pure content focus for maximum ATS compatibility.</p>
          <ul class="space-y-1.5 text-xs text-gray-500 mb-6">
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> Maximum ATS compatibility</li>
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> Pure text, no decoration</li>
            <li class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg> 99.9% ATS pass rate</li>
          </ul>
          <a href="/wizard/ats-minimal" class="block w-full bg-gray-700 hover:bg-gray-800 text-white text-center py-3 rounded-xl font-semibold transition">Use This Template</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 py-8 mt-8">
    <div class="max-w-6xl mx-auto px-4 md:px-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-blue-200/50 text-sm">
        CV Generator — Built with ❤️ for job seekers everywhere
      </div>
      <a href="https://github.com/tiarh/cv-generator" target="_blank" class="text-blue-300 hover:text-white text-sm flex items-center gap-2 transition">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Open Source on GitHub
      </a>
    </div>
  </footer>

</body>
</html>
