<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Job Application Tracker - CV Generator</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>body{font-family:'Inter',sans-serif;}</style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 min-h-screen">

  <header class="py-6 px-4 md:px-8 border-b border-white/10">
    <div class="max-w-5xl mx-auto flex items-center gap-4">
      <a href="/" class="text-blue-200 hover:text-white font-medium text-sm flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </a>
      <div class="w-px h-6 bg-white/20"></div>
      <h1 class="text-white font-bold text-xl">Application Tracker</h1>
    </div>
  </header>

  <main class="max-w-5xl mx-auto px-4 md:px-8 py-10">
    <!-- Stats -->
    <% if (stats) { %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white/10 backdrop-blur rounded-xl p-4 border border-white/10 text-center">
        <div class="text-3xl font-bold text-white"><%= stats.total || 0 %></div>
        <div class="text-blue-200/60 text-xs mt-1">Total</div>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-xl p-4 border border-white/10 text-center">
        <div class="text-3xl font-bold text-blue-400"><%= stats.applied || 0 %></div>
        <div class="text-blue-200/60 text-xs mt-1">Applied</div>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-xl p-4 border border-white/10 text-center">
        <div class="text-3xl font-bold text-yellow-400"><%= stats.interview || 0 %></div>
        <div class="text-blue-200/60 text-xs mt-1">Interview</div>
      </div>
      <div class="bg-white/10 backdrop-blur rounded-xl p-4 border border-white/10 text-center">
        <div class="text-3xl font-bold text-green-400"><%= stats.offered || 0 %></div>
        <div class="text-blue-200/60 text-xs mt-1">Offered</div>
      </div>
    </div>
    <% } %>

    <!-- Add New -->
    <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 mb-8">
      <h2 class="text-white font-bold text-lg mb-4">Add Application</h2>
      <form id="addForm" class="grid md:grid-cols-2 gap-4">
        <input type="text" name="company" required placeholder="Company name"
          class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-blue-200/40 focus:outline-none focus:border-blue-400 transition">
        <input type="text" name="position" required placeholder="Position / Job Title"
          class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-blue-200/40 focus:outline-none focus:border-blue-400 transition">
        <select name="status" class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-400 transition">
          <option value="wishlist" class="text-gray-900">Wishlist</option>
          <option value="applied" class="text-gray-900">Applied</option>
          <option value="interview" class="text-gray-900">Interview</option>
          <option value="offered" class="text-gray-900">Offered</option>
          <option value="rejected" class="text-gray-900">Rejected</option>
        </select>
        <input type="date" name="appliedDate" placeholder="Applied date"
          class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-400 transition">
        <input type="date" name="followUpDate" placeholder="Follow-up date"
          class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-400 transition">
        <input type="text" name="notes" placeholder="Notes (optional)"
          class="bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder-blue-200/40 focus:outline-none focus:border-blue-400 transition">
        <button type="submit" class="bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-xl font-semibold transition md:col-span-2">
          Add Application
        </button>
      </form>
    </div>

    <!-- Kanban Board -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      <% const statuses = [
        { key: 'wishlist', label: 'Wishlist', color: 'gray' },
        { key: 'applied', label: 'Applied', color: 'blue' },
        { key: 'interview', label: 'Interview', color: 'yellow' },
        { key: 'offered', label: 'Offered', color: 'green' },
        { key: 'rejected', label: 'Rejected', color: 'red' }
      ]; %>
      <% statuses.forEach(function(s) { %>
      <div class="bg-white/5 rounded-xl p-3 border border-white/10">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2.5 h-2.5 rounded-full bg-<%= s.color %>-400"></span>
          <span class="text-white font-semibold text-sm"><%= s.label %></span>
          <span class="ml-auto text-blue-200/50 text-xs"><%= apps.filter(function(a) { return a.status === s.key; }).length %></span>
        </div>
        <div class="space-y-2">
          <% apps.filter(function(a) { return a.status === s.key; }).forEach(function(app) { %>
            <div class="bg-white/10 rounded-lg p-3 border border-white/10">
              <p class="text-white text-xs font-medium truncate"><%= app.position %></p>
              <p class="text-blue-200/60 text-xs truncate"><%= app.company %></p>
              <% if (app.appliedDate) { %>
                <p class="text-blue-200/40 text-xs mt-1"><%= new Date(app.appliedDate).toLocaleDateString() %></p>
              <% } %>
            </div>
          <% }); %>
          <% if (apps.filter(function(a) { return a.status === s.key; }).length === 0) { %>
            <p class="text-blue-200/30 text-xs text-center py-4">Empty</p>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
  </main>

<script>
document.getElementById('addForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const data = Object.fromEntries(new FormData(form));
  try {
    const res = await fetch('/applications/api/application', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    if (res.ok) location.reload();
  } catch(err) { alert('Failed to add'); }
});
</script>

</body>
</html>