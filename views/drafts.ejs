<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Drafts | CV Generator</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 min-h-screen">

  <header class="py-6 px-8 border-b border-white/10">
    <div class="max-w-4xl mx-auto flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2"/>
          </svg>
        </div>
        <span class="text-white font-bold text-lg">My Drafts</span>
      </div>
      <a href="/" class="text-blue-300 hover:text-white transition flex items-center gap-2">
        ← Back to Home
      </a>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-8 py-12">
    <% if (drafts && drafts.length > 0) { %>
      <div class="grid gap-4">
        <% drafts.forEach(draft => { %>
        <div class="bg-white rounded-xl p-6 shadow-lg flex justify-between items-center hover:shadow-xl transition">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-1 rounded uppercase"><%= draft.template %></span>
              <span class="text-gray-400 text-sm">Updated: <%= new Date(draft.updated_at).toLocaleDateString() %></span>
            </div>
            <div class="text-gray-900 font-semibold">Draft #<%= draft.id.slice(0, 8) %></div>
          </div>
          <div class="flex gap-2">
            <a href="/draft/<%= draft.id %>" class="bg-blue-600 text-white px-4 py-2 rounded-lg font-medium hover:bg-blue-700 transition text-sm">Edit</a>
            <button onclick="deleteDraft('<%= draft.id %>')" class="bg-red-100 text-red-600 px-4 py-2 rounded-lg font-medium hover:bg-red-200 transition text-sm">Delete</button>
          </div>
        </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-20">
        <div class="w-20 h-20 bg-white/10 rounded-full mx-auto mb-6 flex items-center justify-center">
          <svg class="w-10 h-10 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-white mb-2">No drafts yet</h2>
        <p class="text-blue-200 mb-6">Start creating your first professional resume</p>
        <a href="/" class="bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition inline-flex items-center gap-2">
          Create New CV →
        </a>
      </div>
    <% } %>
  </main>

  <script>
    async function deleteDraft(id) {
      if (!confirm('Delete this draft?')) return;
      try {
        const res = await fetch(`/api/draft/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) location.reload();
      } catch(e) { alert('Delete failed'); }
    }
  </script>
</body>
</html>
